@echo off
title Connect to School

set "CF=%USERPROFILE%\AppData\Local\Microsoft\WinGet\Packages\Cloudflare.cloudflared_Microsoft.Winget.Source_8wekyb3d8bbwe\cloudflared.exe"

echo.
echo ==========================================
echo   Connect to School (YOUR_SUBDOMAIN.ztna.com)
echo   RDP -> localhost:13389
echo   Close this window to disconnect.
echo ==========================================
echo.

sc.exe query cloudflared 2>NUL | findstr /I "RUNNING" >NUL
if %ERRORLEVEL% NEQ 0 (
    echo [!] Tunnel service not running. Starting...
    sc.exe start cloudflared >nul 2>&1
    timeout /t 3 /nobreak >nul
)
echo [OK] Tunnel service is up.
echo [*] Bridging to school...
echo.
"%CF%" access tcp --hostname YOUR_SUBDOMAIN.ztna.com --url localhost:13389

echo.
echo Disconnected.
pause
